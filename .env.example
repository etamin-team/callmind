# Clerk Configuration
CLERK_SECRET_KEY=your_clerk_secret_key_here
CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here

# Paddle Payment Configuration
PADDLE_API_KEY=your_paddle_api_key_here
PADDLE_WEBHOOK_SECRET_KEY=your_paddle_webhook_secret_here
VITE_PADDLE_CLIENT_TOKEN=your_paddle_client_token_here

# Paddle Product Price IDs
# Get these from your Paddle dashboard after creating products
PADDLE_STARTER_MONTHLY_PRICE_ID=
PADDLE_STARTER_YEARLY_PRICE_ID=
PADDLE_PRO_MONTHLY_PRICE_ID=
PADDLE_PRO_YEARLY_PRICE_ID=
PADDLE_BUSINESS_MONTHLY_PRICE_ID=
PADDLE_BUSINESS_YEARLY_PRICE_ID=

# Payme Payment Configuration (Uzbekistan)
# Get these from Payme Business technical specialist
# PAYME_LOGIN: Use "Paycom" for test mode, your merchant ID for production
# PAYME_PASSWORD: Your secret key from Payme Business dashboard
PAYME_MERCHANT_ID=your_payme_merchant_id_here
PAYME_LOGIN=Paycom
PAYME_PASSWORD=your_payme_secret_key_here
PAYME_ENDPOINT_URL=https://checkout.paycom.uz/api
PAYME_CALLBACK_URL=https://your-domain.com

# Payme Price Overrides (in UZS, optional - will use defaults if not set)
# Default prices (1 USD = 12,000 UZS):
# Starter: $9/mo = 108,000 UZS, $86/yr = 1,032,000 UZS
# Pro: $29/mo = 348,000 UZS, $278/yr = 3,336,000 UZS
# Business: $79/mo = 948,000 UZS, $758/yr = 9,096,000 UZS
# PAYME_STARTER_MONTHLY=108000
# PAYME_STARTER_YEARLY=1032000
# PAYME_PRO_MONTHLY=348000
# PAYME_PRO_YEARLY=3336000
# PAYME_BUSINESS_MONTHLY=948000
# PAYME_BUSINESS_YEARLY=9096000

# Frontend Payme Configuration
VITE_PAYME_MERCHANT_ID=your_payme_merchant_id_here

# Environment
NODE_ENV=development

# Gemini AI Configuration
GEMINI_API_KEY=your_gemini_api_key_here
